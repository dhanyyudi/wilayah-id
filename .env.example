# =============================================================
# wilayah-id — Environment Variables Template
# Copy this file to .env.local and fill in your values
# JANGAN commit .env.local ke repository!
# =============================================================

# ── Database ──────────────────────────────────────────────────
# Neon PostgreSQL (production)
DATABASE_URL=postgresql://username:password@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# Self-hosted PostgreSQL (local)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wilayah_id

# ── Tiles ─────────────────────────────────────────────────────
# Base URL untuk vector tiles (default: /tiles = served dari public/tiles/)
NEXT_PUBLIC_TILES_BASE_URL=/tiles

# ── Neon API (untuk MCP tools, opsional) ─────────────────────
# NEON_API_KEY=your_neon_api_key_here
